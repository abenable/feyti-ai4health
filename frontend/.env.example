# The frontend calls the backend via same-origin relative paths (/api/*, /health)
# that Next.js proxies server-side to the internal backend (see next.config.ts).
# You normally do NOT need to set anything here.
#
# Optional overrides:
#   BACKEND_INTERNAL_URL  — where the Next server proxies to (build-time).
#                           Docker sets this to http://backend:8000.
#                           Local dev defaults to http://127.0.0.1:8000.
#   NEXT_PUBLIC_API_URL   — set ONLY to bypass the proxy and have the browser
#                           call the backend directly (not needed for Docker).
